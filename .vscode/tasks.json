{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "cmake",
			"label": "CMake: 빌드",
			"command": "build",
			"targets": [
				"[해당 없음 - 키트 선택]"
			],
			"group": {
				"kind": "test",
				"isDefault": true
			},
			"problemMatcher": [],
			"detail": "CMake 템플릿 빌드 작업"
		},
		{
			"type": "cppbuild",
			"label": "C/C++: cl.exe 활성 파일 빌드",
			"command": "cl.exe",
			"args": [
				"/Zi",
				"/EHsc",
				"/nologo",
				"/Fe${fileDirname}\\${fileBasenameNoExtension}.exe",
				"${file}"
			],
			"options": {
				"cwd": "${fileDirname}"
			},
			"problemMatcher": [
				"$msCompile"
			],
			"group": "build",
			"detail": "컴파일러: cl.exe"
		}
	]
}